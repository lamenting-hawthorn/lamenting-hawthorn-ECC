# Copy to .env for local development. Never commit real secrets.

DATABASE_URL=postgresql:///agent_memory
CHECKPOINTER=memory
MEMORY_BACKEND=fake

# Runtime identity
AGENT_ORG_ID=local_org
OWNER_WHATSAPP_PHONES=
OWNER_TELEGRAM_IDS=

# LLM provider
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Embeddings: local is the default; openai is optional.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Runtime guardrails
AGENT_TOOL_FAILURE_LIMIT=5
AGENT_CONTEXT_COMPACT_AT=0.80
AGENT_MAX_CONTEXT_TOKENS=128000
