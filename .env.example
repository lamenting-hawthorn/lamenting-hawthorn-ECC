# Copy this file to a local `.env` or deployment secret store.
# Never put real keys, tokens, phone numbers, or client data in this file.
#
# Local Homebrew Postgres default: connect over the local socket as the current OS user.
DATABASE_URL=postgresql:///agent_memory
CHECKPOINTER=memory
MEMORY_BACKEND=postgres

WORKER_BATCH_SIZE=50
WORKER_POLL_INTERVAL=5
WORKER_VERBOSE=0

# ---------------------------------------------------------------------------
# LLM (DeepSeek)
# ---------------------------------------------------------------------------
# DeepSeek API (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# ---------------------------------------------------------------------------
# Local Embeddings (sentence-transformers)
# ---------------------------------------------------------------------------
# No API key needed. Runs locally on CPU/GPU.
# Install: pip install sentence-transformers
EMBEDDING_PROVIDER=local
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# Owner IDs (comma-separated)
# ---------------------------------------------------------------------------
OWNER_WHATSAPP_PHONES=
OWNER_TELEGRAM_IDS=

# ---------------------------------------------------------------------------
# Optional external tooling
# ---------------------------------------------------------------------------
# LangSmith is optional for tracing/evals/debugging only.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# n8n is optional for external webhooks/automations only.
N8N_WEBHOOK_BASE_URL=

# ---------------------------------------------------------------------------
# Runtime Guardrails
# ---------------------------------------------------------------------------
AGENT_TOOL_FAILURE_LIMIT=5
AGENT_CONTEXT_COMPACT_AT=0.80
AGENT_MAX_CONTEXT_TOKENS=128000

# ---------------------------------------------------------------------------
# Wiki (Phase 8)
# ---------------------------------------------------------------------------
WIKI_OWNER_USER_ID=u_owner
WIKI_VAULT_PATH=<HOME>/knowledge-base
WIKI_DEFAULT_VISIBILITY=owner_only
